    "document_html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Comparateur de Régimes de Retraite Complémentaire | Votre Simulateur Personnalisé</title>\n    <meta name=\"description\" content=\"Analysez et comparez les différentes options de plans de retraite complémentaire disponibles en France, en évaluant les rendements potentiels, les frais et les fiscalités.\">\n    <style>\n        :root {\n            --color-primary: #0056b3;\n            --color-secondary: #007bff;\n            --color-accent: #28a745;\n            --color-text: #343a40;\n            --color-background: #f8f9fa;\n            --color-card-bg: rgba(255, 255, 255, 0.85);\n            --color-border: rgba(0, 0, 0, 0.1);\n            --font-family-headline: \"Helvetica Neue\", Arial, sans-serif;\n            --font-family-body: \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n        }\n\n        body {\n            font-family: var(--font-family-body);\n            color: var(--color-text);\n            line-height: 1.6;\n            margin: 0;\n            padding: 0;\n            background-color: var(--color-background);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        header {\n            width: 100%;\n            background: linear-gradient(135deg, var(--color-secondary), var(--color-primary));\n            color: white;\n            padding: 4rem 0;\n            text-align: center;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\n            position: relative;\n            overflow: hidden;\n        }\n        header::before {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: radial-gradient(circle at center, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);\n            animation: rotate 20s linear infinite;\n        }\n\n        @keyframes rotate {\n            from { transform: rotate(0deg); }\n            to { transform: rotate(360deg); }\n        }\n\n        h1 {\n            font-family: var(--font-family-headline);\n            font-size: 3.5rem;\n            margin-bottom: 0.5rem;\n            text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.3);\n            position: relative;\n            z-index: 1;\n        }\n\n        header p {\n            font-size: 1.25rem;\n            max-width: 800px;\n            margin: 0 auto;\n            position: relative;\n            z-index: 1;\n        }\n\n        .container {\n            width: 90%;\n            max-width: 1100px;\n            margin: 2rem auto;\n            display: grid;\n            gap: 2rem;\n            grid-template-columns: 1fr;\n        }\n\n        @media (min-width: 768px) {\n            .container {\n                grid-template-columns: 2fr 1fr;\n            }\n        }\n\n        section {\n            background: var(--color-card-bg);\n            padding: 2.5rem;\n            border-radius: 12px;\n            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);\n            border: 1px solid var(--color-border);\n            backdrop-filter: blur(5px);\n            -webkit-backdrop-filter: blur(5px);\n            position: relative;\n        }\n        section::before {\n            content: '';\n            position: absolute;\n            inset: -1px;\n            border-radius: 12px;\n            padding: 1px;\n            background: linear-gradient(45deg, rgba(255,255,255,0.2), rgba(255,255,255,0));\n            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\n            -webkit-mask-composite: xor;\n                    mask-composite: exclude;\n            pointer-events: none;\n        }\n\n\n        h2 {\n            font-family: var(--font-family-headline);\n            color: var(--color-primary);\n            font-size: 2rem;\n            margin-bottom: 1.5rem;\n            border-bottom: 2px solid var(--color-accent);\n            padding-bottom: 0.5rem;\n            display: inline-block;\n        }\n\n        form {\n            display: grid;\n            gap: 1.5rem;\n        }\n\n        .form-group {\n            margin-bottom: 1rem;\n        }\n\n        label {\n            display: block;\n            margin-bottom: 0.6rem;\n            font-weight: bold;\n            color: var(--color-primary);\n        }\n\n        input[type=\"number\"],\n        select {\n            width: calc(100% - 20px);\n            padding: 12px;\n            border: 1px solid var(--color-border);\n            border-radius: 8px;\n            font-size: 1rem;\n            background-color: rgba(255, 255, 255, 0.7);\n            transition: all 0.3s ease;\n        }\n\n        input[type=\"number\"]:focus,\n        select:focus {\n            border-color: var(--color-secondary);\n            box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.25);\n            outline: none;\n        }\n\n        button {\n            background-color: var(--color-accent);\n            color: white;\n            padding: 15px 25px;\n            border: none;\n            border-radius: 8px;\n            font-size: 1.1rem;\n            cursor: pointer;\n            transition: background-color 0.3s ease, transform 0.2s ease;\n            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);\n            font-weight: bold;\n        }\n\n        button:hover {\n            background-color: #218838;\n            transform: translateY(-2px);\n        }\n\n        #tool-result {\n            margin-top: 2rem;\n            padding: 1.5rem;\n            background-color: rgba(230, 247, 255, 0.7);\n            border: 1px solid rgba(0, 123, 255, 0.2);\n            border-radius: 8px;\n            min-height: 100px;\n        }\n\n        #tool-result h3 {\n            color: var(--color-primary);\n            font-size: 1.75rem;\n            margin-top: 0;\n            margin-bottom: 1rem;\n        }\n\n        .result-item {\n            margin-bottom: 1rem;\n            padding-bottom: 1rem;\n            border-bottom: 1px dashed rgba(0, 0, 0, 0.1);\n        }\n        .result-item:last-child {\n            border-bottom: none;\n        }\n        .result-item strong {\n            color: var(--color-secondary);\n        }\n\n        .cta-section {\n            text-align: center;\n            background: linear-gradient(45deg, #e6f7ff, #ffffff);\n            padding: 3rem;\n            margin-top: 2rem;\n            border-radius: 12px;\n            box-shadow: 0 4px 15px rgba(0,0,0,0.08);\n        }\n        .cta-section h2 {\n            color: var(--color-primary);\n            font-size: 2.2rem;\n            margin-bottom: 1.5rem;\n        }\n\n        .info-cards {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n            gap: 1.5rem;\n            margin-top: 2rem;\n        }\n\n        .info-card {\n            background: var(--color-card-bg);\n            padding: 2rem;\n            border-radius: 12px;\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.05);\n            border: 1px solid var(--color-border);\n            text-align: left;\n            transition: transform 0.3s ease;\n        }\n        .info-card:hover {\n            transform: translateY(-5px);\n        }\n        .info-card h3 {\n            color: var(--color-secondary);\n            font-size: 1.5rem;\n            margin-top: 0;\n            margin-bottom: 1rem;\n        }\n        .info-card p {\n            font-size: 0.95rem;\n        }\n        .info-card a {\n            color: var(--color-accent);\n            text-decoration: none;\n            font-weight: bold;\n        }\n        .info-card a:hover {\n            text-decoration: underline;\n        }\n\n        .seo-section {\n            width: 100%;\n            background-color: #f0f2f5;\n            padding: 3rem 0;\n            text-align: center;\n            margin-top: 4rem;\n            border-top: 1px solid var(--color-border);\n        }\n        .seo-section .container {\n            margin: 0 auto;\n            padding: 0 2rem;\n            max-width: 900px;\n            display: block;\n        }\n        .seo-section h2 {\n            color: var(--color-primary);\n            font-size: 2rem;\n            margin-bottom: 1.5rem;\n            border-bottom: none;\n            padding-bottom: 0;\n        }\n        .seo-section p {\n            text-align: left;\n            margin-bottom: 1.2rem;\n            color: #555;\n        }\n        .seo-section ul {\n            text-align: left;\n            list-style-type: disc;\n            padding-left: 20px;\n            color: #555;\n            margin-bottom: 1.5rem;\n        }\n        .seo-section li {\n            margin-bottom: 0.5rem;\n        }\n        .seo-section a {\n            color: var(--color-secondary);\n            text-decoration: none;\n        }\n        .seo-section a:hover {\n            text-decoration: underline;\n        }\n\n        footer {\n            width: 100%;\n            background-color: var(--color-primary);\n            color: white;\n            text-align: center;\n            padding: 1.5rem 0;\n            margin-top: 2rem;\n            font-size: 0.9rem;\n        }\n    </style>\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://comparateur-de-regimes-de-retraite-complementaire-3.onrender.com\">\n    <meta property=\"og:title\" content=\"Comparateur de Régimes de Retraite Complémentaire\">\n    <meta property=\"og:description\" content=\"Analysez et comparez les différentes options de plans de retraite complémentaire disponibles en France, en évaluant les rendements potentiels, les frais et les fiscalités.\">\n    <meta property=\"og:url\" content=\"https://comparateur-de-regimes-de-retraite-complementaire-3.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Comparateur de Régimes de Retraite Complémentaire\", \"description\": \"Analysez et comparez les différentes options de plans de retraite complémentaire disponibles en France, en évaluant les rendements potentiels, les frais et les fiscalités.\", \"url\": \"https://comparateur-de-regimes-de-retraite-complementaire-3.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"comparateur-de-regimes-de-retraite-complementaire-3\" data-runtime-mode=\"tax_calculator\">\n    <header>\n        <h1>Simplifiez Votre Retraite Complémentaire en France</h1>\n        <p>Analysez, comparez et choisissez le régime de retraite complémentaire qui correspond le mieux à vos objectifs financiers et à votre profil fiscal.</p>\n    </header>\n\n    <div class=\"container\">\n        <section>\n            <h2>Votre Simulateur Personnalisé</h2>\n            <p>Entrez vos informations pour obtenir une comparaison éclairée des principaux régimes de retraite complémentaire disponibles en France (PER individuel, Madelin, etc.).</p>\n            <form id=\"tool-form\">\n                <div class=\"form-group\">\n                    <label for=\"age\">Votre Âge Actuel (années)</label>\n                    <input type=\"number\" id=\"age\" value=\"35\" min=\"18\" max=\"65\" required>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"revenuAnnuel\">Revenu Annuel Brut (EUR)</label>\n                    <input type=\"number\" id=\"revenuAnnuel\" value=\"40000\" min=\"10000\" step=\"1000\" required>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"epargneMensuelle\">Épargne Mensuelle Prévue (EUR)</label>\n                    <input type=\"number\" id=\"epargneMensuelle\" value=\"150\" min=\"10\" step=\"10\" required>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"horizonRetraite\">Âge de Départ à la Retraite Prévu (années)</label>\n                    <input type=\"number\" id=\"horizonRetraite\" value=\"65\" min=\"55\" max=\"70\" required>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"tauxImposition\">Tranche d'Imposition Actuelle (%)</label>\n                    <select id=\"tauxImposition\" required>\n                        <option value=\"0\">0%</option>\n                        <option value=\"11\">11%</option>\n                        <option value=\"30\" selected>30%</option>\n                        <option value=\"41\">41%</option>\n                        <option value=\"45\">45%</option>\n                    </select>\n                </div>\n                <button type=\"submit\" id=\"tool-submit\">Comparer les Régimes</button>\n            </form>\n\n            <div id=\"tool-result\">\n                <h3 id=\"result-headline\">Résultats de la Simulation</h3>\n                <p>Vos estimations de rendements potentiels, frais et avantages fiscaux apparaîtront ici après simulation.</p>\n            </div>\n        </section>\n\n        <section>\n            <h2>Pourquoi Comparer ?</h2>\n            <p>Naviguer dans les options de retraite complémentaire en France peut être complexe. Notre outil vous aide à comprendre l'impact de chaque choix sur votre avenir financier, en prenant en compte :</p>\n            <ul>\n                <li><strong>Rendements Potentiels :</strong> Estimez la croissance de votre capital.</li>\n                <li><strong>Frais de Gestion :</strong> Visualisez l'impact des coûts sur votre épargne.</li>\n                <li><strong>Avantages Fiscaux :</strong> Découvrez les économies d'impôts réalisables.</li>\n                <li><strong>Flexibilité :</strong> Comprenez les conditions de sortie et de transfert.</li>\n            </ul>\n            <p>Une décision éclairée aujourd'hui, c'est une retraite plus sereine demain.</p>\n        </section>\n    </div>\n\n    <section class=\"cta-section\">\n        <h2>Préparez Votre Avenir Dès Aujourd'hui</h2>\n        <p>Ne laissez pas la complexité des produits financiers vous freiner. Notre outil est là pour vous donner les clés d'une planification retraite réussie. C'est simple, rapide et adapté à votre situation.</p>\n        <button data-affiliate-slot=\"premium-guide\">Accéder à un guide expert (PDF)</button>\n    </section>\n\n    <div class=\"container info-cards\">\n        <div class=\"info-card\">\n            <h3>PER : Le Nouveau Standard</h3>\n            <p>Découvrez le Plan d'Épargne Retraite (PER), ses avantages fiscaux et sa flexibilité. Est-il fait pour vous ?</p>\n            <a href=\"#\" data-affiliate-slot=\"per-info\">En savoir plus sur le PER</a>\n        </div>\n        <div class=\"info-card\">\n            <h3>Frais et Performances</h3>\n            <p>Comprenez l'importance des frais de gestion et leur impact à long terme sur la performance de votre épargne retraite.</p>\n            <a href=\"#\" data-affiliate-slot=\"fees-performance-info\">Analyser les frais</a>\n        </div>\n        <div class=\"info-card\">\n            <h3>Fiscalité de la Retraite</h3>\n            <p>Maîtrisez la fiscalité à l'entrée et à la sortie de votre épargne retraite pour optimiser votre gain net.</p>\n            <a href=\"#\" data-affiliate-slot=\"tax-info\">Optimiser votre fiscalité</a>\n        </div>\n    </div>\n\n    <section class=\"seo-section\">\n        <div class=\"container\">\n            <h2>Retraite Complémentaire en France : Guide Complet pour Particuliers</h2>\n            <p>Optimiser sa retraite est une préoccupation majeure pour de nombreux Français. Face à la complexité des dispositifs comme le <a href=\"#\">PER (Plan d'Épargne Retraite)</a>, le Madelin ou les contrats d'assurance vie dédiés à la retraite, il est essentiel de disposer d'outils clairs pour faire les meilleurs choix. Notre comparateur en ligne a été conçu pour vous aider à y voir plus clair.</p>\n            <p>Que vous soyez salarié, indépendant, profession libérale ou dirigeant d'entreprise, les options de retraite complémentaire peuvent varier considérablement en termes de:</p>\n            <ul>\n                <li><strong>Rendement potentiel :</strong> Quel sera le capital généré à l'âge de la retraite ?</li>\n                <li><strong>Frais de gestion :</strong> Comment ces coûts impactent-ils la performance réelle de votre épargne ?</li>\n                <li><strong>Avantages fiscaux :</strong> Quelles réductions d'impôts pouvez-vous obtenir à l'entrée et à la sortie du dispositif ?</li>\n                <li><strong>Conditions de sortie :</strong> Capital, rente, déblocage anticipé... Quelles sont les flexibilités offertes ?</li>\n            </ul>\n            <p>Utilisez notre simulateur pour évaluer l'impact de votre âge, de votre revenu annuel, de votre capacité d'épargne et de votre tranche d'imposition sur le rendement futur de votre plan de retraite. Comparez les <a href=\"#\">meilleurs PER individuels</a> du marché, analysez les différences entre un PER assurance et un PER bancaire, et comprenez comment la loi PACTE a simplifié et harmonisé l'épargne retraite en France.</p>\n            <p>Préparez sereinement votre avenir financier en quelques clics et prenez une décision éclairée pour votre retraite.</p>\n        </div>\n    </section>\n\n    <footer>\n        © 2023 Comparateur de Retraite Complémentaire. Tous droits réservés.\n    </footer>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(event) {\n            event.preventDefault();\n\n            const age = parseInt(document.getElementById('age').value);\n            const revenuAnnuel = parseInt(document.getElementById('revenuAnnuel').value);\n            const epargneMensuelle = parseInt(document.getElementById('epargneMensuelle').value);\n            const horizonRetraite = parseInt(document.getElementById('horizonRetraite').value);\n            const tauxImposition = parseInt(document.getElementById('tauxImposition').value) / 100;\n\n            const anneesRestantes = horizonRetraite - age;\n            const epargneAnnuelle = epargneMensuelle * 12;\n\n            // Simplistic model for demonstration, not financial advice\n            const rendementMoyenPER = 0.04; // 4% annuel\n            const fraisMoyensPER = 0.01; // 1% annuel sur l'encours\n            const reductionFiscalePER = epargneAnnuelle * tauxImposition; // Hypothèse simple de déduction fiscale à l'entrée\n\n            const rendementMoyenMadelin = 0.035; // 3.5% annuel\n            const fraisMoyensMadelin = 0.015; // 1.5% annuel\n            // La déduction fiscale Madelin est plus complexe, mais on simplifie pour l'exemple\n            const reductionFiscaleMadelin = epargneAnnuelle * tauxImposition * 0.9; // Légèrement moins avantageux pour l'exemple\n\n            let capitalPER = 0;\n            let capitalMadelin = 0;\n            let totalFraisPER = 0;\n            let totalFraisMadelin = 0;\n\n            for (let i = 0; i < anneesRestantes; i++) {\n                capitalPER += epargneAnnuelle;\n                let fraisAnnuelsPER = capitalPER * fraisMoyensPER;\n                capitalPER -= fraisAnnuelsPER;\n                capitalPER *= (1 + rendementMoyenPER);\n                totalFraisPER += fraisAnnuelsPER;\n\n                capitalMadelin += epargneAnnuelle;\n                let fraisAnnuelsMadelin = capitalMadelin * fraisMoyensMadelin;\n                capitalMadelin -= fraisAnnuelsMadelin;\n                capitalMadelin *= (1 + rendementMoyenMadelin);\n                totalFraisMadelin += fraisAnnuelsMadelin;\n            }\n\n            const resultDiv = document.getElementById('tool-result');\n            resultDiv.innerHTML = `\n                <h3>Vos Projections de Retraite</h3>\n                <p>Basé sur vos informations et des hypothèses de marché simplifiées :</p>\n\n                <div class=\"result-item\">\n                    <h4>Plan d'Épargne Retraite (PER)</h4>\n                    <p>Capital estimé à la retraite : <strong>${capitalPER.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 })}</strong></p>\n                    <p>Frais totaux estimés sur la période : <strong>${totalFraisPER.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 })}</strong></p>\n                    <p>Réduction fiscale annuelle estimée (entrée) : <strong>${reductionFiscalePER.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 })}</strong></p>\n                    <p><em>Avantages : Plus de flexibilité à la sortie (capital ou rente), cadre fiscal harmonisé.</em></p>\n                </div>\n\n                <div class=\"result-item\">\n                    <h4>Contrat Madelin (pour Indépendants)</h4>\n                    <p>Capital estimé à la retraite : <strong>${capitalMadelin.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 })}</strong></p>\n                    <p>Frais totaux estimés sur la période : <strong>${totalFraisMadelin.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 })}</strong></p>\n                    <p>Réduction fiscale annuelle estimée (entrée) : <strong>${reductionFiscaleMadelin.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 })}</strong></p>\n                    <p><em>Avantages : Déduction des versements du bénéfice imposable (pour indépendants), rente viagère garantie.</em></p>\n                </div>\n                <p><em>Ces chiffres sont des estimations basées sur des hypothèses simplifiées et ne constituent pas un conseil financier. Les rendements passés ne préjugent pas des rendements futurs.</em></p>\n            `;\n        });\n    </script>\n<div id=\"qa-smoke-result\" hidden></div>\n<script id=\"farmbuilder-affiliate-helper\">\n(function () {\n  window.__UTILITY_AFFILIATE_MAP = window.__UTILITY_AFFILIATE_MAP || {};\n  document.addEventListener(\"click\", function (event) {\n    const target = event.target.closest(\"[data-affiliate-slot]\");\n    if (!target) return;\n    const slot = target.getAttribute(\"data-affiliate-slot\");\n    const href = window.__UTILITY_AFFILIATE_MAP[slot];\n    if (!href) return;\n    if (target.tagName && target.tagName.toLowerCase() === \"a\") {\n      target.setAttribute(\"href\", href);\n      target.removeAttribute(\"rel\");\n      return;\n    }\n    event.preventDefault();\n    window.open(href, \"_blank\");\n  }, true);\n})();\n</script>\n<script id=\"farmbuilder-functional-qa\">\n(function () {\n  function marker() {\n    let node = document.getElementById(\"qa-smoke-result\");\n    if (node) return node;\n    node = document.createElement(\"div\");\n    node.id = \"qa-smoke-result\";\n    node.hidden = true;\n    document.body.appendChild(node);\n    return node;\n  }\n\n  let qaFinished = false;\n  let qaWatchdog = null;\n\n  function normalize(text) {\n    return String(text || \"\").replace(/\\s+/g, \" \").trim();\n  }\n\n  function findForm() {\n    return document.getElementById(\"tool-form\") || document.querySelector(\"form\");\n  }\n\n  function findResult() {\n    return (\n      document.getElementById(\"tool-result\") ||\n      document.querySelector(\"[data-result]\") ||\n      document.querySelector(\".tool-result, .result-card, .result, .results, .output, .preview, .diagnostic, .analysis\")\n    );\n  }\n\n  function primaryAction(form) {\n    if (!form) return null;\n    return (\n      document.getElementById(\"tool-submit\") ||\n      form.quer